{
  "globalBg": "https://pbs.twimg.com/media/Dd2EsNZVMAAIsSK.jpg",

  "bot": {
    "name": "Nat AI",
    "version": "0.4",
    "style": "friendly, casual, slightly nerdy",
    "language": "th-th",
    "memory_enabled": true
  },

  "resources": [
    {
      "name": "โค้ดเว็บหน้าแรก",
      "url": "https://github.com/natthawatjunthawe/kbios.nat.ai.free.com/blob/main/index.html",
      "type": "code"
    },
    {
      "name": "CSS หลัก",
      "url": "https://github.com/natthawatjunthawe/kbios.nat.ai.free.com/blob/main/style.css",
      "type": "code"
    },
    {
      "name": "ระบบ AI logic",
      "url": "https://github.com/natthawatjunthawe/kbios.nat.ai.free.com/blob/main/script.js",
      "type": "code"
    },
    {
      "name": "ไฟล์โมเดลหลัก",
      "url": "https://github.com/natthawatjunthawe/kbios.nat.ai.free.com/blob/main/db.json",
      "type": "code"
    },
    {
      "name": "รูปพื้นหลัง",
      "url": "https://pbs.twimg.com/media/Dd2EsNZVMAAIsSK.jpg",
      "type": "image"
    }
  ],

  "intents": [
    {
      "tag": "greeting",
      "patterns": [
        "สวัสดี",
        "สวัสดีครับ",
        "สวัดดี",
        "หวัดดี",
        "hello",
        "hi",
        "ดีครับ",
        "ดีจ้า"
      ],
      "responses": [
        "สวัสดีครับ {u} 👋 มีอะไรให้ Nat AI ช่วยไหม",
        "หวัดดี {u} 😄 วันนี้อยากทำอะไรกับ AI ตัวนี้ครับ"
      ]
    },

    {
      "tag": "name_typo",
      "patterns": [
        "มึงชื่ออะไร",
        "ชื่อไร",
        "ชื่ออะไรอะ",
        "ชื่ออาราย",
        "นายชื่อไร",
        "เธอชื่ออะไร"
      ],
      "responses": [
        "ผมชื่อ Nat AI ครับ 😄 เป็น AI ที่สร้างจาก JSON + JavaScript"
      ]
    },

    {
      "tag": "ask_project",
      "patterns": [
        "นี่คืออะไร",
        "เว็บนี้คืออะไร",
        "ทำอะไรได้",
        "อธิบายหน่อย",
        "มันคืออะไร"
      ],
      "responses": [
        "นี่คือ Nat AI เป็น AI แบบ customizable ที่ใช้ JSON model และ JavaScript ควบคุม",
        "มันคือ AI sandbox ที่ให้คนสร้าง personality เองได้ครับ 😎"
      ]
    },

    {
      "tag": "error_typo_greeting",
      "patterns": [
        "สวัดดีครับ",
        "สวสดี",
        "สวัสด",
        "หวัดดีครับ"
      ],
      "responses": [
        "สวัสดีครับ 😄 (ผมเข้าใจว่าคุณพิมพ์ผิดนิดหน่อย)"
      ]
    },

    {
      "tag": "thanks",
      "patterns": [
        "ขอบคุณ",
        "thx",
        "thank you",
        "ขอบคุน",
        "ขอบใจ"
      ],
      "responses": [
        "ยินดีครับ {u} 😄",
        "ไม่เป็นไรเลย 👍"
      ]
    },

    {
      "tag": "ai_definition",
      "patterns": [
        "AI คืออะไร",
        "เอไอคืออะไร",
        "ai คือ",
        "มันคือ ai แบบไหน"
      ],
      "responses": [
        "AI คือระบบที่พยายามเลียนแบบความคิดมนุษย์ แต่ตัวนี้เป็นแบบ rule + JSON ครับ 😄"
      ]
    },

    {
      "tag": "fallback",
      "patterns": [],
      "responses": [
        "ขออภัยครับ ผมยังไม่เข้าใจ 😅 ลองถามใหม่ได้ไหม",
        "ผมยังไม่มีข้อมูลในส่วนนี้ครับ"
      ]
    }
  ]
}